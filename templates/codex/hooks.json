{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {CODEX_HOME}/hooks/self_improve_hook.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {CODEX_HOME}/hooks/self_improve_hook.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {CODEX_HOME}/hooks/self_improve_hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {CODEX_HOME}/hooks/self_improve_hook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {CODEX_HOME}/hooks/self_improve_hook.py"
          }
        ]
      }
    ]
  }
}
